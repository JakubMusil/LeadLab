# =============================================================================
# LeadLab — environment variables template for Docker Compose
# =============================================================================
# Copy this file to .env and adjust the values before running:
#   cp .env.example .env
#
# The values below are pre-configured for the Docker Compose setup
# (Option A in install.md).  When running without Docker, replace
# "db" / "redis" with "localhost" and set DB_ENGINE to SQLite if preferred.
# =============================================================================

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------

# Generate a secure key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-generate-a-real-secret-key

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database (PostgreSQL — matches the "db" service in docker-compose.yml)
# ---------------------------------------------------------------------------

DB_ENGINE=django.db.backends.postgresql
DB_NAME=leadlab
DB_USER=leadlab
DB_PASSWORD=leadlab
DB_HOST=db
DB_PORT=5432

# ---------------------------------------------------------------------------
# Redis (matches the "redis" service in docker-compose.yml)
# Used as Celery broker, result backend, channel layer, and cache.
# ---------------------------------------------------------------------------

REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Stripe (leave empty to disable subscription features)
# ---------------------------------------------------------------------------

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ---------------------------------------------------------------------------
# Email (defaults to console backend — emails are printed to stdout)
# ---------------------------------------------------------------------------

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@leadlab.io

# ---------------------------------------------------------------------------
# AWS S3 (optional — leave empty to use local media storage)
# ---------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-central-1

# ---------------------------------------------------------------------------
# Web Push / VAPID (optional)
# Generate keys with:
#   python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); print('Private:', v.private_key()); print('Public:', v.public_key())"
# ---------------------------------------------------------------------------

VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_ADMIN_EMAIL=admin@leadlab.io

# ---------------------------------------------------------------------------
# Brute-force protection (django-axes)
# ---------------------------------------------------------------------------

AXES_FAILURE_LIMIT=10
AXES_ENABLE=True

# ---------------------------------------------------------------------------
# Error tracking (optional — Sentry is only initialised when DSN is set)
# ---------------------------------------------------------------------------

SENTRY_DSN=

# ---------------------------------------------------------------------------
# Content Security Policy (optional — sensible defaults are built in)
# ---------------------------------------------------------------------------

# CSP_DEFAULT_SRC='self'
# CSP_SCRIPT_SRC='self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdn.jsdelivr.net
# CSP_STYLE_SRC='self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net
# CSP_FONT_SRC='self' https://fonts.gstatic.com
# CSP_IMG_SRC='self' data: blob:
# CSP_CONNECT_SRC='self' wss: ws:
# CSP_WORKER_SRC='self' blob:
# CSP_REPORT_URI=

# ---------------------------------------------------------------------------
# Seed / demo data (used by the Docker Compose web startup command)
# The database is flushed and reseeded with demo data on every container start.
# Override these to change the superadmin login credentials.
# ---------------------------------------------------------------------------

SEED_EMAIL=info@jakubmusil.cz
SEED_PASSWORD=login

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------

# Set to False to disable API rate limiting globally (e.g. during development)
RATELIMIT_ENABLE=True

# Public base URL of the frontend; used in Stripe redirect URLs
FRONTEND_URL=
